#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

pattern='^(feat|fix|docs|chore|refactor|test|build|ci|perf|style|revert|ops)(\([a-z0-9._/-]+\))?!?: .{1,72}$|^Merge .*$|^Revert .*$'

if [[ ! "$first_line" =~ $pattern ]]; then
  cat >&2 <<'EOF'
Invalid commit message.

Use Conventional Commits:
  type(scope): short summary

Allowed types:
  feat, fix, docs, chore, refactor, test, build, ci, perf, style, revert, ops

Examples:
  chore: add project quality hooks
  fix(deploy): resolve Podman database host mapping
  docs(workflow): document review report process
EOF
  exit 1
fi
