# LiteLLM gateway authentication
LITELLM_MASTER_KEY=sk-change-me

# LiteLLM persistence database. Current deployment expects PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/litellm?sslmode=disable

# OpenAI-compatible upstream used by config/litellm.yaml
ICA_BASE=https://example.com/v1
ICA_KEY=change-me

# Optional local runtime overrides
LITELLM_HOST=0.0.0.0
LITELLM_PORT=4001
# LITELLM_CONFIG=/absolute/path/to/config/litellm.yaml
